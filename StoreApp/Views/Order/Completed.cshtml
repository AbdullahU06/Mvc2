@model int

<div class="container my-5 text-center">
    <div class="py-5 bg-white rounded-4 shadow-sm border border-light-subtle">
        <h1 class="display-3 text-success mb-3"><i class="fa-solid fa-circle-check"></i></h1>
        <h1 class="display-5 fw-bold text-dark">Thank You!</h1>
        <p class="lead text-muted mt-3 mb-4">
            Hello, your order has been successfully placed. <br />
            We will process it carefully and ship your goods as soon as possible.
        </p>
        
        <div class="d-inline-flex align-items-center bg-light border rounded-pill px-4 py-2 mb-4 shadow-sm">
            <span class="text-secondary fw-bold text-uppercase me-2"><i class="fa-solid fa-hashtag me-1"></i>Order Number:</span>
            <span class="fs-4 fw-bold text-primary">@Model</span>
        </div>
        
        <div class="mt-4">
            <a class="btn btn-primary btn-lg shadow rounded-pill px-5" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-house me-2"></i>Return to Store
            </a>
        </div>
    </div>
</div>
