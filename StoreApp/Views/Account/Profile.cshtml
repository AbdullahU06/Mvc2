@model StoreApp.Models.ProfileViewModel

<div class="row justify-content-center mt-5">
    <div class="col-md-7">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:56px;height:56px;background:#3b82f6;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;
                        color:white;font-size:22px;font-weight:700;">
                @Model.FirstName.Substring(0, 1).ToUpper()
            </div>
            <div>
                <h4 class="mb-0">@Model.FirstName @Model.LastName</h4>
                <small class="text-muted">@Model.Email</small>
            </div>
        </div>

        <!-- Profil Bilgileri -->
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-bold">
                <i class="fa-solid fa-user me-2 text-primary"></i>Profil Bilgileri
            </div>
            <div class="card-body">
                <form asp-action="Profile" method="post">
                    <input type="hidden" asp-for="Email" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label fw-semibold">Ad</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label fw-semibold">Soyad</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input value="@Model.Email" class="form-control" disabled />
                        <small class="text-muted">Email adresi değiştirilemez.</small>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Kaydet
                    </button>
                </form>
            </div>
        </div>

        <!-- Şifre Değiştir -->
        <div class="card shadow-sm">
            <div class="card-header fw-bold">
                <i class="fa-solid fa-lock me-2 text-warning"></i>Şifre Değiştir
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mevcut Şifre</label>
                        <input name="CurrentPassword" type="password" class="form-control" placeholder="••••••" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Yeni Şifre</label>
                        <input name="NewPassword" type="password" class="form-control" placeholder="••••••" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Yeni Şifre Tekrar</label>
                        <input name="ConfirmNewPassword" type="password" class="form-control" placeholder="••••••" />
                    </div>
                    <button type="submit" class="btn btn-warning">
                        <i class="fa-solid fa-key me-1"></i> Şifreyi Değiştir
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
