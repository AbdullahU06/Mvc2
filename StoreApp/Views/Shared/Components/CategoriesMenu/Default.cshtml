@using Store.Entities.Models
@model IEnumerable<Category>

<a asp-controller="Product" asp-action="Index" asp-route-categoryId=""
   class="cat-pill @(string.IsNullOrEmpty(ViewBag.SelectedCategory?.ToString()) ? "active" : "")">
    <span class="cat-dot"></span>
    Tüm Ürünler
</a>

@foreach (var cat in Model)
{
    <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.CategoryId"
       class="cat-pill @(ViewBag.SelectedCategory?.ToString() == cat.CategoryId.ToString() ? "active" : "")">
        <span class="cat-dot"></span>
        @cat.CategoryName
    </a>
}
