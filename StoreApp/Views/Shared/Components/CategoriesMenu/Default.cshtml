@using Store.Entities.Models
@model IEnumerable<Category>
<div>
    <div class="list-group">
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="" 
           class="list-group-item list-group-item-action @(string.IsNullOrEmpty(ViewBag.SelectedCategory?.ToString()) ? "active" : "")">
            <i class="fa-solid fa-layer-group me-2"></i>Tüm Ürünler (All)
        </a>
        @foreach (var cat in Model)
        {
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.CategoryId"
               class="list-group-item list-group-item-action @(ViewBag.SelectedCategory?.ToString() == cat.CategoryId.ToString() ? "active" : "")">
                <i class="fa-solid fa-angle-right me-2"></i>@cat.CategoryName
            </a>
        }
    </div>
</div>