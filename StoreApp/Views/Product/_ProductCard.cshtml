@model Product

@section Footer {
    <div>
        Onyl for index footer
    </div>

}



<div class="col-sm-12 col-md-4 col-lg-3 my-2">

    <div class="card" style="width: 18rem;">
        <img src="/images/default.jpg" class="card-img-top" alt="...">
        <div class="card-body">
            <h5 class="card-title">@Model.ProductName</h5>
            <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card’s
                content.</p>
            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Get" asp-route-id="@Model.ProductId" class="btn btn-primary">
                    <i class="fa-solid fa-arrow-right"></i> Details
                </a>
                
                <form asp-page="/Cart" method="post">
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <input type="hidden" name="returnUrl" value="/Product" />
                    <button type="submit" class="btn btn-success rounded-pill">
                        <i class="fa-solid fa-cart-plus"></i> Add
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>