@model Entities.Product

<div class="col-sm-6 col-lg-4">
    <div class="pcard">
        <a asp-action="Get" asp-route-id="@Model.ProductId" class="pcard-img-wrap">
            @if (string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="pcard-placeholder">
                    <i class="fa-solid fa-image"></i>
                </div>
            }
            else
            {
                <img src="@Model.ImageUrl" alt="@Model.ProductName" class="pcard-img" />
            }
            <div class="pcard-overlay">
                <span><i class="fa-solid fa-eye me-1"></i> İncele</span>
            </div>
        </a>

        <div class="pcard-body">
            <h6 class="pcard-name" title="@Model.ProductName">@Model.ProductName</h6>
            <div class="pcard-price">@Model.Price.ToString("N0") ₺</div>

            <form asp-page="/Cart" method="post" class="mt-auto">
                <input type="hidden" name="productId" value="@Model.ProductId" />
                <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
                <button type="submit" class="pcard-btn">
                    <i class="fa-solid fa-cart-plus me-1"></i> Sepete Ekle
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    .pcard {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #dce8e0;
        transition: transform .2s, box-shadow .2s;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 1px 6px rgba(27,58,45,.06);
    }
    .pcard:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 36px rgba(27,58,45,.14);
    }
    .pcard-img-wrap {
        position: relative;
        display: block;
        overflow: hidden;
        height: 220px;
        background: #f0f5f1;
        text-decoration: none;
    }
    .pcard-img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform .35s;
    }
    .pcard:hover .pcard-img { transform: scale(1.06); }
    .pcard-placeholder {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        color: #b0c8bb; font-size: 48px;
    }
    .pcard-overlay {
        position: absolute; inset: 0;
        background: rgba(27,58,45,.55);
        display: flex; align-items: center; justify-content: center;
        color: #c8a840; font-size: 14px; font-weight: 700;
        opacity: 0; transition: opacity .2s;
        letter-spacing: .3px;
    }
    .pcard:hover .pcard-overlay { opacity: 1; }
    .pcard-body {
        padding: 16px;
        display: flex; flex-direction: column; flex: 1;
        border-top: 2px solid #f0f5f1;
    }
    .pcard-name {
        font-size: 14px; font-weight: 700; color: #1b3a2d;
        margin-bottom: 6px;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
        line-height: 1.4;
    }
    .pcard-price {
        font-size: 20px; font-weight: 900; color: #c8a840;
        margin-bottom: 14px;
        letter-spacing: -.3px;
    }
    .pcard-btn {
        width: 100%; padding: 10px;
        background: #1b3a2d; color: #c8a840;
        border: none; border-radius: 10px;
        font-size: 13px; font-weight: 700;
        cursor: pointer; transition: all .15s;
        letter-spacing: .2px;
    }
    .pcard-btn:hover { background: #2d5a3d; color: white; }
</style>
