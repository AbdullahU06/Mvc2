@model Entities.Product

<div class="col-sm-12 col-md-6 col-lg-4 col-xl-3">
    <div class="card h-100 shadow-sm border-0 transition-hover">
        @if(string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="/images/default.jpg" class="card-img-top" alt="@Model.ProductName" style="height: 200px; object-fit: cover;">
        }
        else
        {
            <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.ProductName" style="height: 200px; object-fit: cover;">
        }
        
        <div class="card-body d-flex flex-column">
            <h5 class="card-title text-truncate fw-bold" title="@Model.ProductName">@Model.ProductName</h5>
            <h6 class="text-success mb-3 fw-bold">@Model.Price.ToString("C")</h6>
            
            <p class="card-text text-muted flex-grow-1" style="font-size: 0.85rem;">
                Harika bir ürün, stoklarımızda sizleri bekliyor. Seçiminizle fark yaratın!
            </p>
            
            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                <a asp-action="Get" asp-route-id="@Model.ProductId" class="btn btn-outline-primary btn-sm fw-bold">
                    <i class="fa-solid fa-circle-info"></i> Details
                </a>
                
                <form asp-page="/Cart" method="post" class="m-0">
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
                    <button type="submit" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm fw-bold">
                        <i class="fa-solid fa-cart-plus"></i> Add
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>