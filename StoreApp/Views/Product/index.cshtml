@model IQueryable<Product>


<div class="row">
    <div class="col-3">
        @await Component.InvokeAsync("CategoriesMenu")
    </div>
    <div class="col-9">
        <div class="row my-3">
            @foreach (var prd in Model)
            {
                <partial name="_ProductCard" model="@prd" />
            }
        </div>
    </div>
</div>