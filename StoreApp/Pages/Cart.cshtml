@page "/cart"
@model StoreApp.Pages.CartModel

<div class="row mt-4">
    <div class="col-12">
        <h2 class="display-6"><i class="fa-solid fa-cart-shopping"></i> Your Cart (Alışveriş Sepeti)</h2>
        
        @if(Model.Cart?.Lines.Count == 0)
        {
             <div class="alert alert-warning mt-3">Your cart is empty. (Sepetiniz boş.)</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-bordered table-striped mt-3 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Subtotal</th>
                            <th class="text-center">Remove</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.Cart?.Lines ?? Enumerable.Empty<Entities.Models.CartLine>())
                        {
                            <tr>
                                <td>@line.Product.ProductName</td>
                                <td class="text-center">@line.Quantity</td>
                                <td class="text-end">@line.Product.Price.ToString("C")</td>
                                <td class="text-end">@((line.Product.Price * line.Quantity).ToString("C"))</td>
                                <td class="text-center">
                                    <form method="post" asp-page-handler="Remove">
                                        <input type="hidden" name="productId" value="@line.Product.ProductId" />
                                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fa-solid fa-trash"></i> Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Total:</td>
                            <td class="text-end fw-bold text-success fs-5">
                                @Model.Cart?.ComputeTotalValue().ToString("C")
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }

        <div class="text-center mt-4">
            <a class="btn btn-primary" href="@Model.ReturnUrl"><i class="fa-solid fa-arrow-left"></i> Continue Shopping</a>
            @if(Model.Cart?.Lines.Count > 0)
            {
                <a class="btn btn-success" href="/Order/Checkout"><i class="fa-solid fa-credit-card"></i> Checkout</a>
            }
        </div>
    </div>
</div>
