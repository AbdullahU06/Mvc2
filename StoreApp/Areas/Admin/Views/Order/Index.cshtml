@model IQueryable<Order>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Siparişler";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h2>Siparişler</h2>
        <p>Tüm siparişleri buradan yönetebilirsin</p>
    </div>
    @if (ViewBag.NumberOfInProcess > 0)
    {
        <span class="badge fs-6 px-3 py-2" style="background:#fff7ed; color:#f97316; border:1px solid #fed7aa;">
            <i class="fa-solid fa-hourglass-half me-1"></i> @ViewBag.NumberOfInProcess Bekleyen
        </span>
    }
</div>

@if (!Model.Any())
{
    <div class="admin-card p-5 text-center">
        <i class="fa-solid fa-inbox fa-3x mb-3 text-muted"></i>
        <p class="text-muted mb-0">Henüz hiç sipariş yok.</p>
    </div>
}
else
{
    <div class="admin-card">
        <div class="admin-card-header">
            <h5><i class="fa-solid fa-cart-shopping me-2 text-warning"></i>Sipariş Listesi</h5>
            <span class="badge bg-warning text-dark">@Model.Count() sipariş</span>
        </div>
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Sipariş #</th>
                        <th>Müşteri</th>
                        <th>Şehir</th>
                        <th>Hediye Paketi</th>
                        <th>Durum</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><span class="badge bg-primary rounded-pill">#@order.OrderId</span></td>
                            <td class="fw-semibold">@order.Name</td>
                            <td>@order.City</td>
                            <td>
                                @if (order.GiftWrap)
                                {
                                    <span class="badge" style="background:#fdf4ff; color:#a855f7;">
                                        <i class="fa-solid fa-gift me-1"></i>Evet
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted">Hayır</span>
                                }
                            </td>
                            <td>
                                @if (order.Shipped)
                                {
                                    <span class="badge" style="background:#f0fdf4; color:#16a34a;">
                                        <i class="fa-solid fa-circle-check me-1"></i>Teslim Edildi
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#fff7ed; color:#ea580c;">
                                        <i class="fa-solid fa-hourglass-half me-1"></i>Bekliyor
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                @if (!order.Shipped)
                                {
                                    <form asp-area="Admin" asp-controller="Order" asp-action="Complete" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@order.OrderId" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="fa-solid fa-truck-fast me-1"></i>Teslim Edildi İşaretle
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
