@model IQueryable<Order>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="fa-solid fa-box-open text-primary me-2"></i>Order Management
        </h2>
        <span class="badge bg-warning text-dark fs-6 px-3 py-2 shadow-sm">
            <i class="fa-solid fa-clock me-1"></i>In Process: @ViewBag.NumberOfInProcess
        </span>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm border-0 text-center py-4">
            <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
            <span class="fs-5">No orders yet.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm rounded overflow-hidden">
                <thead class="table-dark">
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>City</th>
                        <th>Gift Wrap</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><span class="badge bg-primary rounded-pill">#@order.OrderId</span></td>
                            <td class="fw-bold">@order.Name</td>
                            <td>@order.City</td>
                            <td>
                                @if (order.GiftWrap)
                                {
                                    <span class="badge bg-danger"><i class="fa-solid fa-gift me-1"></i>Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                @if (order.Shipped)
                                {
                                    <span class="badge bg-success px-3 py-2">
                                        <i class="fa-solid fa-circle-check me-1"></i>Shipped
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2">
                                        <i class="fa-solid fa-hourglass-half me-1"></i>In Process
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                @if (!order.Shipped)
                                {
                                    <form asp-area="Admin" asp-controller="Order" asp-action="Complete" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@order.OrderId" />
                                        <button type="submit" class="btn btn-sm btn-success shadow-sm">
                                            <i class="fa-solid fa-truck-fast me-1"></i>Mark Shipped
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
