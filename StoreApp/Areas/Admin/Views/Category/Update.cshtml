@model Store.Entities.Models.Category
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kategori Düzenle";
}

<div class="page-header">
    <h2>Kategori Düzenle</h2>
    <p>#@Model.CategoryId numaralı kategoriyi güncelle</p>
</div>

<div class="form-card">
    <form asp-action="Update" method="post">
        <input type="hidden" asp-for="CategoryId" />
        <div class="mb-4">
            <label asp-for="CategoryName" class="form-label">Kategori Adı</label>
            <input asp-for="CategoryName" class="form-control" />
            <span asp-validation-for="CategoryName" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning">
                <i class="fa-solid fa-pen-to-square me-1"></i> Güncelle
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>
