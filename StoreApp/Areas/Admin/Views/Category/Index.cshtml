@model IEnumerable<Store.Entities.Models.Category>

<h3>Category Index</h3>
<p>
    <a class="btn btn-success" asp-area="Admin" asp-controller="Category" asp-action="Create">Create New Category</a>
</p>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CategoryId</td>
                <td>@item.CategoryName</td>
                <td>
                    <a class="btn btn-primary btn-sm" asp-area="Admin" asp-controller="Category" asp-action="Details"
                       asp-route-id="@item.CategoryId">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>