@model IEnumerable<Store.Entities.Models.Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kategoriler";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h2>Kategoriler</h2>
        <p>Tüm kategorileri buradan yönetebilirsin</p>
    </div>
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Category" asp-action="Create">
        <i class="fa-solid fa-plus me-1"></i> Yeni Kategori
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h5><i class="fa-solid fa-tags me-2 text-success"></i>Kategori Listesi</h5>
        <span class="badge bg-success">@Model.Count() kategori</span>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Kategori Adı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge bg-light text-dark">#@item.CategoryId</span></td>
                        <td class="fw-semibold">@item.CategoryName</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-area="Admin" asp-controller="Category" asp-action="Update" asp-route-id="@item.CategoryId">
                                    <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                </a>
                                <form asp-area="Admin" asp-controller="Category" asp-action="Delete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.CategoryId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Bu kategoriyi silmek istediğinden emin misin?')">
                                        <i class="fa-solid fa-trash"></i> Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
