@model Entities.Dtos.ProductDtoForInsertion
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yeni Ürün";
}

<div class="page-header">
    <h2>Yeni Ürün Ekle</h2>
    <p>Mağazana yeni bir ürün ekle</p>
</div>

<div class="form-card">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label asp-for="ProductName" class="form-label">Ürün Adı</label>
            <input asp-for="ProductName" class="form-control" placeholder="Ürün adını girin" />
            <span asp-validation-for="ProductName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Price" class="form-label">Fiyat (₺)</label>
            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
            <span asp-validation-for="Price" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CategoryId" class="form-label">Kategori</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                <option value="">-- Kategori Seçiniz --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="File" class="form-label">Ürün Görseli</label>
            <input type="file" asp-for="File" class="form-control" accept="image/*"
                   onchange="previewImage(this, 'imgPreviewCreate')" />
            <span asp-validation-for="File" class="text-danger small"></span>
            <div class="mt-2">
                <img id="imgPreviewCreate" src="#" alt="Önizleme"
                     style="display:none; max-height:180px; border-radius:8px; border:1px solid #e2e8f0;" />
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk me-1"></i> Kaydet
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>
